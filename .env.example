# Firebase Web SDK config (tarayıcıya gider)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# App Check — reCAPTCHA v3 site key (tarayıcı)
NEXT_PUBLIC_APPCHECK_SITE_KEY=

# Tek-kiracı modunda sabit restoran kimliği
NEXT_PUBLIC_RESTORAN_ID=

# Admin SDK (yalnız sunucu) — service account JSON'unun tek satır halinde tamamı
FIREBASE_SERVICE_ACCOUNT=

# İlk kasiyer/sahip atamasını koruyan tek kullanımlık jeton
ADMIN_SETUP_TOKEN=

# Opsiyonel: scripts/seed.mjs çalışırken claim atanacak kullanıcı e-postası
SEED_SAHIP_EMAIL=
