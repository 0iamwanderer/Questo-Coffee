# Firebase Web SDK config (tarayıcıya gider)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# App Check — reCAPTCHA v3 site key (tarayıcı)
NEXT_PUBLIC_APPCHECK_SITE_KEY=

# Tek-kiracı modunda sabit restoran kimliği
NEXT_PUBLIC_RESTORAN_ID=

# Admin SDK (yalnız sunucu) — şu yollardan biri:
#  a) tek satır JSON: FIREBASE_SERVICE_ACCOUNT='{"project_id":"..."}'
#  b) dosya yolu  : FIREBASE_SERVICE_ACCOUNT_PATH=./service-account.json
FIREBASE_SERVICE_ACCOUNT=
FIREBASE_SERVICE_ACCOUNT_PATH=

# İlk kasiyer/sahip atamasını koruyan tek kullanımlık jeton
ADMIN_SETUP_TOKEN=

# Opsiyonel: scripts/seed.mjs çalışırken claim atanacak kullanıcı e-postası
SEED_SAHIP_EMAIL=

# ── Emulator ile geliştirme (production'da boş bırak) ───────────────
# 'localhost' Windows'ta IPv6 (::1) çözülebilir, emulator IPv4'te dinler;
# 127.0.0.1 kullanmak en güvenlisi.
# NEXT_PUBLIC_USE_EMULATOR=1
# FIRESTORE_EMULATOR_HOST=127.0.0.1:8080
# FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099
# FIREBASE_STORAGE_EMULATOR_HOST=127.0.0.1:9199
