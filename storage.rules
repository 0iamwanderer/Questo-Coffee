rules_version = '2';

// Ürün görselleri — herkes okur, yalnız sahip yazar (en fazla 2 MB, image/*).
service firebase.storage {
  match /b/{bucket}/o {

    match /restoranlar/{restoranId}/urunler/{urunId}/{file=**} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.token.rol == 'kasiyer'
        && request.auth.token.sahip == true
        && request.auth.token.restoranId == restoranId
        && request.resource.size < 2 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null
        && request.auth.token.rol == 'kasiyer'
        && request.auth.token.sahip == true
        && request.auth.token.restoranId == restoranId;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
